{
  "info": {
    "name": "Messaging App API Tests",
    "description": "Collection to test conversations, messages and JWT authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login - Get JWT Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://127.0.0.1:8000/api/token/", "protocol": "http", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "token", ""] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password\"\n}"
        }
      }
    },
    {
      "name": "Create Conversation",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://127.0.0.1:8000/api/chats/conversations/", "protocol": "http", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "chats", "conversations", ""] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"participants\": [1, 2]\n}"
        }
      }
    },
    {
      "name": "Send Message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://127.0.0.1:8000/api/chats/messages/", "protocol": "http", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "chats", "messages", ""] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"conversation\": 1,\n  \"content\": \"Hello from Postman!\"\n}"
        }
      }
    },
    {
      "name": "Fetch Conversations",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "url": { "raw": "http://127.0.0.1:8000/api/chats/conversations/", "protocol": "http", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "chats", "conversations", ""] }
      }
    },
    {
      "name": "Fetch Messages (Paginated)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "url": { "raw": "http://127.0.0.1:8000/api/chats/messages/?page=1", "protocol": "http", "host": ["127.0.0.1"], "port": "8000", "path": ["api", "chats", "messages", ""], "query": [{ "key": "page", "value": "1" }] }
      }
    }
  ],
  "variable": [
    { "key": "jwt_token", "value": "" }
  ]
}
